        score
    }
    
    fn calculate_backrun_score(&self, tx_info: &TransactionInfo) -> u32 {
        // Similar scoring for backrun transactions
        0
    }
    
    fn calculate_optimal_slippage(&self, risk: &SandwichRisk) -> u64 {
        let base_slippage = 100; // 1%
        
        let risk_multiplier = match risk.score {
            0..=30 => 1.0,
            31..=60 => 2.0,
            61..=80 => 3.0,
            _ => 5.0,
        };
        
        let frontrun_count_multiplier = 1.0 + (risk.frontrun_transactions.len() as f64 * 0.5);
        
        ((base_slippage as f64) * risk_multiplier * frontrun_count_multiplier) as u64
    }
    
    fn extract_priority_fee(&self, tx: &Transaction) -> u64 {
        // Extract compute unit price from transaction
        for ix in &tx.message.instructions {
            if ix.program_id == solana_sdk::compute_budget::id() {
                // Parse compute unit price
                if ix.data.len() >= 9 && ix.data[0] == 3 {
                    return u64::from_le_bytes(ix.data[1..9].try_into().unwrap());
                }
            }
        }
        0
    }
}

#[derive(Debug, Clone)]
struct CachedAnalysis {
    risk: SandwichRisk,
    timestamp: Instant,
}

#[derive(Debug, thiserror::Error)]
pub enum SandwichError {
    #[error("Mempool error: {0}")]
    MempoolError(String),
    #[error("Analysis timeout")]
    Timeout,
}