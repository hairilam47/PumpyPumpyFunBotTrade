    pub sol_amount: u64,
    pub token_amount: u64,
    pub timestamp: i64,
}

// ============================================
// Error Codes
// ============================================

#[error_code]
pub enum ErrorCode {
    #[msg("Name must be 32 characters or less")]
    NameTooLong,
    #[msg("Symbol must be 10 characters or less")]
    SymbolTooLong,
    #[msg("URI must be 200 characters or less")]
    UriTooLong,
    #[msg("Invalid amount")]
    InvalidAmount,
    #[msg("Slippage tolerance exceeded")]
    SlippageExceeded,
    #[msg("Insufficient reserves")]
    InsufficientReserves,
    #[msg("Bonding curve is complete")]
    BondingCurveComplete,
    #[msg("Not ready for migration")]
    NotReadyForMigration,
    #[msg("Already migrated")]
    AlreadyMigrated,
}