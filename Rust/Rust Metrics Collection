// metrics.rs
use prometheus::{
    Counter, Gauge, Histogram, HistogramOpts, IntCounter, IntGauge,
    Registry, TextEncoder, Encoder,
};
use std::sync::Arc;
use warp::Filter;

#[derive(Clone)]
pub struct Metrics {
    registry: Registry,
    
    // Order metrics
    pub orders_submitted: IntCounter,
    pub orders_executed: IntCounter,
    pub orders_failed: IntCounter,
    pub orders_rejected: IntCounter,
    pub order_execution_time: Histogram,
    
    // Trading metrics
    pub total_volume_sol: Counter,
    pub total_trades: IntCounter,
    pub winning_trades: IntCounter,
    pub losing_trades: IntCounter,
    pub total_pnl_sol: Gauge,
    pub daily_pnl_sol: Gauge,
    
    // Position metrics
    pub active_positions: IntGauge,
    pub total_exposure_sol: Gauge,
    
    // MEV metrics
    pub sandwich_attacks_detected: IntCounter,
    pub mev_protected_trades: IntCounter,
    
    // RPC metrics
    pub rpc_requests: IntCounter,
    pub rpc_errors: IntCounter,
    pub rpc_latency: Histogram,
    
    // System metrics
    pub wallet_balance: Gauge,
    pub memory_usage: Gauge,
    pub cpu_usage: Gauge,
}

impl Metrics {
    pub fn new() -> Result<Self, prometheus::Error> {
        let registry = Registry::new();
        
        let orders_submitted = IntCounter::new(
            "pumpfun_orders_submitted_total",
            "Total number of orders submitted"
        )?;
        registry.register(Box::new(orders_submitted.clone()))?;
        
        let orders_executed = IntCounter::new(
            "pumpfun_orders_executed_total",
            "Total number of orders executed"
        )?;
        registry.register(Box::new(orders_executed.clone()))?;
        
        let orders_failed = IntCounter::new(
            "pumpfun_orders_failed_total",
            "Total number of orders failed"
        )?;
        registry.register(Box::new(orders_failed.clone()))?;
        
        let orders_rejected = IntCounter::new(
            "pumpfun_orders_rejected_total",
            "Total number of orders rejected"
        )?;
        registry.register(Box::new(orders_rejected.clone()))?;
        
        let order_execution_time = Histogram::with_opts(
            HistogramOpts::new(
                "pumpfun_order_execution_seconds",
                "Order execution time in seconds"
            )
            .buckets(vec![0.1, 0.25, 0.5, 1.0, 2.0, 5.0, 10.0])
        )?;
        registry.register(Box::new(order_execution_time.clone()))?;
        
        let total_volume_sol = Counter::new(
            "pumpfun_total_volume_sol",
            "Total trading volume in SOL"
        )?;
        registry.register(Box::new(total_volume_sol.clone()))?;
        
        let total_trades = IntCounter::new(
            "pumpfun_total_trades",
            "Total number of trades"
        )?;
        registry.register(Box::new(total_trades.clone()))?;
        
        let winning_trades = IntCounter::new(
            "pumpfun_winning_trades",
            "Number of winning trades"
        )?;
        registry.register(Box::new(winning_trades.clone()))?;
        
        let losing_trades = IntCounter::new(
            "pumpfun_losing_trades",
            "Number of losing trades"
        )?;
        registry.register(Box::new(losing_trades.clone()))?;
        
        let total_pnl_sol = Gauge::new(
            "pumpfun_total_pnl_sol",
            "Total PnL in SOL"
        )?;
        registry.register(Box::new(total_pnl_sol.clone()))?;
        
        let daily_pnl_sol = Gauge::new(
            "pumpfun_daily_pnl_sol",
            "Daily PnL in SOL"
        )?;
        registry.register(Box::new(daily_pnl_sol.clone()))?;
        
        let active_positions = IntGauge::new(
            "pumpfun_active_positions",
            "Number of active positions"
        )?;
        registry.register(Box::new(active_positions.clone()))?;
        
        let total_exposure_sol = Gauge::new(
            "pumpfun_total_exposure_sol",
            "Total portfolio exposure in SOL"
        )?;
        registry.register(Box::new(total_exposure_sol.clone()))?;
        
        let sandwich_attacks_detected = IntCounter::new(
            "pumpfun_sandwich_attacks_detected_total",
            "Total sandwich attacks detected"
        )?;
        registry.register(Box::new(sandwich_attacks_detected.clone()))?;
        
        let mev_protected_trades = IntCounter::new(
            "pumpfun_mev_protected_trades_total",
            "Total trades protected with MEV bundles"
        )?;
        registry.register(Box::new(mev_protected_trades.clone()))?;
        
        let rpc_requests = IntCounter::new(
            "pumpfun_rpc_requests_total",
            "Total RPC requests"
        )?;
        registry.register(Box::new(rpc_requests.clone()))?;
        
        let rpc_errors = IntCounter::new(
            "pumpfun_rpc_errors_total",
            "Total RPC errors"
        )?;
        registry.register(Box::new(rpc_errors.clone()))?;
        
        let rpc_latency = Histogram::with_opts(
            HistogramOpts::new(
                "pumpfun_rpc_latency_seconds",
                "RPC latency in seconds"
            )
            .buckets(vec![0.01, 0.05, 0.1, 0.25, 0.5, 1.0, 2.0, 5.0])
        )?;
        registry.register(Box::new(rpc_latency.clone()))?;
        
        let wallet_balance = Gauge::new(
            "pumpfun_wallet_balance_sol",
            "Wallet balance in SOL"
        )?;
        registry.register(Box::new(wallet_balance.clone()))?;
        
        let memory_usage = Gauge::new(
            "pumpfun_memory_usage_bytes",
            "Memory usage in bytes"
        )?;
        registry.register(Box::new(memory_usage.clone()))?;
        
        let cpu_usage = Gauge::new(
            "pumpfun_cpu_usage_percent",
            "CPU usage percentage"
        )?;
        registry.register(Box::new(cpu_usage.clone()))?;
        
        Ok(Self {
            registry,
            orders_submitted,
            orders_executed,
            orders_failed,
            orders_rejected,
            order_execution_time,
            total_volume_sol,
            total_trades,
            winning_trades,
            losing_trades,
            total_pnl_sol,
            daily_pnl_sol,
            active_positions,
            total_exposure_sol,
            sandwich_attacks_detected,
            mev_protected_trades,
            rpc_requests,
            rpc_errors,
            rpc_latency,
            wallet_balance,
            memory_usage,
            cpu_usage,
        })
    }
    
    pub async fn start_server(&self, port: u16) {
        let registry = self.registry.clone();
        
        let metrics_route = warp::path("metrics")
            .map(move || {
                let encoder = TextEncoder::new();
                let metric_families = registry.gather();
                let mut buffer = vec![];
                encoder.encode(&metric_families, &mut buffer).unwrap();
                String::from_utf8(buffer).unwrap()
            });
        
        let health_route = warp::path("health")
            .map(|| "OK");
        
        let routes = metrics_route.or(health_route);
        
        warp::serve(routes)
            .run(([0, 0, 0, 0], port))
            .await;
    }
}